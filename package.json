{
  "name": "next-temp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node -e \"const {execSync,spawnSync}=require('child_process');try{const r=execSync('netstat -ano').toString();const m=r.match(/TCP.*:3000.*LISTENING.*?(\\d+)/);if(m)spawnSync('taskkill',['/F','/PID',m[1]],{stdio:'ignore'})}catch{}try{require('fs').rmSync('.next/dev',{recursive:true,force:true})}catch{}\"",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
